---
import Layout from './Layout.astro';

interface Props {
  title: string;
  date: Date;
  location: string;
  excerpt: string;
  voyage?: string;
  migrated?: boolean;
  lat?: number;
  lon?: number;
  coverPhoto?: string;
  anchorage?: string;
  marina?: string;
}

const { title, date, location, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={excerpt}>
  <div class="max-w-[720px] mx-auto px-6 py-12">
    <article>
      <!-- Post title -->
      <h1 class="font-inter font-bold text-[28px] text-ink leading-[1.2] mb-4">
        {title}
      </h1>

      <!-- Meta row: date + location -->
      <div class="flex gap-4 items-center mb-8">
        <time
          datetime={date.toISOString().slice(0, 10)}
          class="font-inter text-[14px] text-muted"
        >
          {formattedDate}
        </time>
        {location && (
          <span class="font-inter text-[14px] text-muted">&mdash; {location}</span>
        )}
      </div>

      <!-- Post body: MDX content -->
      <div class="post-body">
        <slot />
      </div>
    </article>
  </div>
</Layout>

<style>
  /* Scope prose styles to post body so they don't affect nav */
  .post-body {
    font-family: var(--font-lora), Georgia, serif;
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .post-body h2 {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .post-body h3 {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-ink);
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .post-body p {
    margin-bottom: 1.5em;
  }

  .post-body a {
    color: var(--color-brass);
    text-decoration: underline;
  }

  .post-body a:hover {
    color: #a88a3d;
  }

  .post-body ul,
  .post-body ol {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }

  .post-body li {
    margin-bottom: 0.5em;
  }

  .post-body blockquote {
    border-left: 3px solid var(--color-brass);
    padding-left: 1em;
    margin-left: 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--color-navy);
    margin: 2em 0;
  }
</style>
