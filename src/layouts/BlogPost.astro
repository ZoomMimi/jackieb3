---
import Layout from './Layout.astro';

interface NavLink {
  id: string;
  title: string;
}

interface Props {
  title: string;
  date: Date;
  location: string;
  excerpt: string;
  voyage?: string;
  migrated?: boolean;
  lat?: number;
  lon?: number;
  coverPhoto?: string;
  anchorage?: string;
  marina?: string;
  prev?: NavLink | null;
  next?: NavLink | null;
}

const { title, date, location, excerpt, prev, next } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={excerpt}>
  <div class="max-w-[720px] mx-auto px-6 py-12">
    <article>
      <!-- Post title -->
      <h1 class="font-inter font-bold text-[28px] text-ink leading-[1.2] mb-4">
        {title}
      </h1>

      <!-- Meta row: date + location -->
      <div class="flex gap-4 items-center mb-8">
        <time
          datetime={date.toISOString().slice(0, 10)}
          class="font-inter text-[14px] text-muted"
        >
          {formattedDate}
        </time>
        {location && (
          <span class="font-inter text-[14px] text-muted">&mdash; {location}</span>
        )}
      </div>

      <!-- Post body: MDX content -->
      <div class="post-body">
        <slot />
      </div>
    </article>

    <!-- Post navigation -->
    <nav class="post-nav">
      <div class="post-nav-prev">
        {prev && (
          <a href={`/blog/${prev.id}`}>
            <span class="post-nav-arrow">←</span>
            <span class="post-nav-label">Previous</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-next">
        {next && (
          <a href={`/blog/${next.id}`}>
            <span class="post-nav-title">{next.title}</span>
            <span class="post-nav-label">Next</span>
            <span class="post-nav-arrow">→</span>
          </a>
        )}
      </div>
    </nav>
  </div>
</Layout>

<style>
  /* Scope prose styles to post body so they don't affect nav */
  .post-body {
    font-family: var(--font-lora), Georgia, serif;
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .post-body h2 {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .post-body h3 {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-ink);
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .post-body p {
    margin-bottom: 1.5em;
  }

  .post-body a {
    color: var(--color-brass);
    text-decoration: underline;
  }

  .post-body a:hover {
    color: #991515;
  }

  .post-body ul,
  .post-body ol {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }

  .post-body li {
    margin-bottom: 0.5em;
  }

  .post-body blockquote {
    border-left: 3px solid var(--color-brass);
    padding-left: 1em;
    margin-left: 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--color-navy);
    margin: 2em 0;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .post-nav-prev,
  .post-nav-next {
    flex: 1;
    min-width: 0;
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    color: var(--color-ink);
  }

  .post-nav a:hover .post-nav-title {
    color: var(--color-brass);
  }

  .post-nav-arrow {
    font-size: 1.25rem;
    color: var(--color-navy);
  }

  .post-nav-label {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .post-nav-title {
    font-family: var(--font-inter), system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
