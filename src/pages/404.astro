---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Jackie B III Going Loopy" description="The page you are looking for does not exist.">
  <div class="max-w-[720px] mx-auto px-6 py-16 text-center">
    <h1 class="font-inter font-bold text-[28px] text-ink leading-[1.2] mb-4">Page Not Found</h1>
    <p class="font-lora text-[18px] text-ink leading-[1.7] mb-8">
      Page not found &mdash; navigate home or browse the Great Loop.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/"
        class="font-inter font-bold text-[18px] text-brass no-underline hover:underline hover:text-[#991515] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
      >
        &larr; Home
      </a>
      <span class="hidden sm:inline font-inter text-[18px] text-muted">&middot;</span>
      <a
        href="/voyages/great-loop/"
        class="font-inter font-bold text-[18px] text-brass no-underline hover:underline hover:text-[#991515] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
      >
        Browse the Great Loop &rarr;
      </a>
    </div>
  </div>
</Layout>
