---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="All Posts — Jackie B III Going Loopy" description="All posts from the Jackie B III Great Loop voyage.">
  <div class="max-w-[720px] mx-auto px-6 py-12">
    <h1 class="font-inter font-bold text-[28px] text-ink leading-[1.2] mb-8">All Posts</h1>
    {posts.length === 0 ? (
      <p class="font-lora text-[18px] text-muted">No posts yet. The voyage begins soon.</p>
    ) : (
      <ul class="list-none p-0 m-0">
        {posts.map((post, i) => (
          <li>
            {i > 0 && <hr class="border-0 border-t border-navy my-6" />}
            <article class="py-2">
              <time
                datetime={post.data.date.toISOString().slice(0, 10)}
                class="font-inter text-[14px] text-muted block mb-1"
              >
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="font-inter font-bold text-[20px] leading-[1.3] mb-2 mt-0">
                <a
                  href={`/blog/${post.id}`}
                  class="text-brass no-underline hover:underline hover:text-[#991515] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="font-lora text-[18px] text-ink leading-[1.7] mb-2">{post.data.excerpt}</p>
              <p class="font-inter text-[14px] text-muted">{post.data.location}</p>
            </article>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
