---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
  return sorted.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      prev: i > 0 ? { id: sorted[i - 1].id, title: sorted[i - 1].data.title } : null,
      next: i < sorted.length - 1 ? { id: sorted[i + 1].id, title: sorted[i + 1].data.title } : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prev={prev} next={next}>
  <Content />
</BlogPost>
