---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const posts = await getCollection('blog', ({ data }) => data.voyage === 'great-loop');

const sortedPosts = posts.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<Layout
  title="Great Loop — Jackie B III Going Loopy"
  description="The full Great Loop voyage aboard Jackie B III, 2022–2024. 5,424 nautical miles documented stop by stop."
>
  <div class="max-w-[720px] mx-auto px-6 py-12">
    <!-- Page heading -->
    <h1 class="font-inter font-bold text-[28px] text-ink leading-[1.2] mb-2">Great Loop</h1>
    <p class="font-inter text-[14px] text-muted mb-10">2022&ndash;2024 &middot; 5,424 nm</p>

    <!-- Phase 5: interactive route map goes here -->

    {sortedPosts.length === 0 ? (
      <div class="text-center py-8">
        <p class="font-lora text-[18px] text-muted mb-2">No posts yet. The voyage begins soon.</p>
        <p class="font-inter text-[14px] text-muted">This section will fill in as posts are published. Check back soon.</p>
      </div>
    ) : (
      <ul class="list-none p-0 m-0">
        {sortedPosts.map((post, i) => (
          <li>
            {i > 0 && <hr class="border-0 border-t border-navy my-6" />}
            <article class="py-2">
              <time
                datetime={post.data.date.toISOString().slice(0, 10)}
                class="font-inter text-[14px] text-muted block mb-1"
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="font-inter font-bold text-[20px] leading-[1.3] mb-2 mt-0">
                <a
                  href={`/blog/${post.id}`}
                  class="text-brass no-underline hover:underline hover:text-[#991515] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="font-lora text-[18px] text-ink leading-[1.7] mb-2">
                {post.data.excerpt}
              </p>
              <p class="font-inter text-[14px] text-muted">
                {post.data.location}
              </p>
            </article>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
