---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('blog');

const recentPosts = allPosts
  .filter(({ data }) => data.voyage === 'great-loop')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout title="Jackie B III Going Loopy" description="Jackie B III on the Great Loop, 2022–2024. A powerboat voyage documented stop by stop.">
  <!-- Hero -->
  <section class="w-full bg-navy py-16 md:py-16 text-center" style="padding-top: 64px; padding-bottom: 64px;">
    <div class="max-w-[720px] mx-auto px-6">
      <h1 class="font-inter font-bold text-[36px] text-offwhite leading-[1.2] mb-4">
        Going Loopy
      </h1>
      <p class="font-inter text-[18px] text-muted mb-8">
        Jackie B III on the Great Loop, 2022&ndash;2024
      </p>
      <a
        href="/voyages/great-loop/"
        class="font-inter font-bold text-[18px] text-brass hover:text-[#a88a3d] no-underline hover:underline focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
      >
        Read the voyage &rarr;
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="max-w-[720px] mx-auto px-6 py-12">
    <h2 class="font-inter font-bold text-[20px] text-ink mb-8">Recent Posts</h2>

    {recentPosts.length === 0 ? (
      <div class="text-center py-8">
        <p class="font-lora text-[18px] text-muted mb-2">No posts yet. The voyage begins soon.</p>
        <p class="font-inter text-[14px] text-muted">This section will fill in as posts are published. Check back soon.</p>
      </div>
    ) : (
      <ul class="list-none p-0 m-0">
        {recentPosts.map((post, i) => (
          <li>
            {i > 0 && <hr class="border-0 border-t border-navy my-6" />}
            <article class="py-2">
              <time
                datetime={post.data.date.toISOString().slice(0, 10)}
                class="font-inter text-[14px] text-muted block mb-1"
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h3 class="font-inter font-bold text-[20px] leading-[1.3] mb-2 mt-0">
                <a
                  href={`/blog/${post.id}`}
                  class="text-brass no-underline hover:underline hover:text-[#a88a3d] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
                >
                  {post.data.title}
                </a>
              </h3>
              <p class="font-lora text-[18px] text-ink leading-[1.7] mb-2">
                {post.data.excerpt}
              </p>
              <p class="font-inter text-[14px] text-muted">
                {post.data.location}
              </p>
            </article>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-8 pt-6 border-t border-navy">
      <a
        href="/voyages/great-loop/"
        class="font-inter font-bold text-[18px] text-brass no-underline hover:underline hover:text-[#a88a3d] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
      >
        View all posts &rarr;
      </a>
    </div>
  </section>
</Layout>
