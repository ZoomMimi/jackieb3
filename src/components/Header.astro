---
interface Props {
  pathname?: string;
}

const { pathname = Astro.url.pathname } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="w-full bg-navy h-16 md:h-16" style="height: 64px;">
  <div class="max-w-[1200px] mx-auto px-6 h-full flex items-center justify-between">
    <!-- Site name -->
    <a
      href="/"
      class="font-inter font-bold text-brass text-[18px] no-underline tracking-wide hover:opacity-90 focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none"
    >
      JACKIE B III
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main" class="hidden md:flex items-center gap-8">
      <a
        href="/"
        aria-current={isActive('/') ? 'page' : undefined}
        class="font-inter font-bold text-white text-[18px] no-underline hover:underline decoration-[#b91c1c] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none [&[aria-current=page]]:underline [&[aria-current=page]]:decoration-[#b91c1c] [&[aria-current=page]]:decoration-2"
      >
        Home
      </a>
      <a
        href="/voyages/great-loop/"
        aria-current={isActive('/voyages/great-loop') ? 'page' : undefined}
        class="font-inter font-bold text-white text-[18px] no-underline hover:underline decoration-[#b91c1c] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none [&[aria-current=page]]:underline [&[aria-current=page]]:decoration-[#b91c1c] [&[aria-current=page]]:decoration-2"
      >
        Great Loop
      </a>
      <a
        href="/about/"
        aria-current={isActive('/about') ? 'page' : undefined}
        class="font-inter font-bold text-white text-[18px] no-underline hover:underline decoration-[#b91c1c] focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none [&[aria-current=page]]:underline [&[aria-current=page]]:decoration-[#b91c1c] [&[aria-current=page]]:decoration-2"
      >
        About
      </a>
    </nav>

    <!-- Mobile hamburger (no JS — details/summary) -->
    <details class="md:hidden relative">
      <summary
        aria-label="Toggle navigation"
        class="list-none cursor-pointer text-white focus-visible:ring-2 focus-visible:ring-brass focus-visible:outline-none min-h-[44px] flex items-center"
      >
        <!-- Hamburger icon: 3 horizontal lines -->
        <svg
          aria-hidden="true"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <nav
        aria-label="Main"
        class="absolute right-0 top-full w-screen bg-navy flex flex-col z-50 shadow-lg"
        style="right: -24px; width: 100vw;"
      >
        <a
          href="/"
          aria-current={isActive('/') ? 'page' : undefined}
          class="font-inter font-bold text-white text-[18px] no-underline px-6 flex items-center min-h-[44px] hover:bg-[#233d61] [&[aria-current=page]]:text-brass"
        >
          Home
        </a>
        <a
          href="/voyages/great-loop/"
          aria-current={isActive('/voyages/great-loop') ? 'page' : undefined}
          class="font-inter font-bold text-white text-[18px] no-underline px-6 flex items-center min-h-[44px] hover:bg-[#233d61] [&[aria-current=page]]:text-brass"
        >
          Great Loop
        </a>
        <a
          href="/about/"
          aria-current={isActive('/about') ? 'page' : undefined}
          class="font-inter font-bold text-white text-[18px] no-underline px-6 flex items-center min-h-[44px] hover:bg-[#233d61] [&[aria-current=page]]:text-brass"
        >
          About
        </a>
      </nav>
    </details>
  </div>
</header>
