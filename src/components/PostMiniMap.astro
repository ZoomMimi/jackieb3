---
// PostMiniMap.astro
// Per-post Leaflet mini map.
// D-05: one instance per page maximum.
// D-07: no polyline until track data is available; fitBounds when start+end present.
// D-08: caller (BlogPost.astro) guards — only rendered when lat/lon present.

interface Props {
  lat: number;
  lon: number;
  location: string;
  startLat?: number;
  startLon?: number;
  track?: [number, number][];
  photos?: [number, number, number][]; // [lat, lon, unixTs]
}

const { lat, lon, location, startLat, startLon, track = [], photos = [] } = Astro.props;

function serialize(x: unknown): string {
  return JSON.stringify(x).replace(/</g, '\\u003c');
}

const hasStart = startLat !== undefined && startLon !== undefined;
---

<div
  id="post-mini-map"
  data-lat={lat}
  data-lon={lon}
  data-start-lat={hasStart ? startLat : undefined}
  data-start-lon={hasStart ? startLon : undefined}
  class="h-56 w-full rounded mb-8"
  style="z-index: 0;"
  aria-label={`Map showing the stop at ${location}`}
>
  Map could not load. Refresh the page to try again.
</div>
<script type="application/json" id="post-mini-map-track" set:html={serialize(track)}></script>
<script type="application/json" id="post-mini-map-photos" set:html={serialize(photos)}></script>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const el = document.getElementById('post-mini-map') as HTMLElement | null;
  if (!el) throw new Error('post-mini-map element not found');

  const endLat = Number(el.dataset.lat);
  const endLon = Number(el.dataset.lon);

  if (Number.isFinite(endLat) && Number.isFinite(endLon)) {
    el.textContent = '';

    const hasStart = el.dataset.startLat !== undefined && el.dataset.startLon !== undefined;
    const startLat = hasStart ? Number(el.dataset.startLat) : NaN;
    const startLon = hasStart ? Number(el.dataset.startLon) : NaN;

    let track: [number, number][] = [];
    let photos: [number, number, number][] = [];
    try { track  = JSON.parse(document.getElementById('post-mini-map-track')?.textContent  ?? '[]'); } catch {}
    try { photos = JSON.parse(document.getElementById('post-mini-map-photos')?.textContent ?? '[]'); } catch {}

    const map = L.map(el, {
      dragging: false,
      zoomControl: false,
      scrollWheelZoom: false,
      attributionControl: true,
    });

    L.tileLayer(
      'https://tiles.stadiamaps.com/tiles/outdoors/{z}/{x}/{y}{r}.png?api_key=e4945b3a-7773-42ec-a6d5-f6e9eecd88e9',
      {
        attribution:
          '&copy; <a href="https://stadiamaps.com/">Stadia Maps</a> &copy; <a href="https://openmaptiles.org/">OpenMapTiles</a> &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 20,
        detectRetina: true,
      }
    ).addTo(map);

    // Route polyline (once GPX track data exists)
    if (track.length > 1) {
      L.polyline(track, { color: '#1e3a5f', weight: 2, opacity: 0.8 }).addTo(map);
    }

    // Photo location dots — small sky-blue circles, popup shows time taken
    for (const [pLat, pLon, ts] of photos) {
      const time = new Date(ts * 1000).toLocaleTimeString('en-US', {
        hour: 'numeric', minute: '2-digit', hour12: true,
        timeZone: 'America/New_York',
      });
      L.circleMarker([pLat, pLon], {
        radius: 3,
        fillColor: '#0ea5e9',
        fillOpacity: 0.75,
        stroke: false,
      }).bindPopup(`📷 ${time}`, { closeButton: false }).addTo(map);
    }

    // Start (green) and end (red) named-stop markers on top
    const endIcon = L.divIcon({
      html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" width="14" height="14"><circle cx="7" cy="7" r="5.5" fill="#b91c1c" stroke="white" stroke-width="2"/></svg>',
      iconSize: [14, 14], iconAnchor: [7, 7], className: '',
    });
    const startIcon = L.divIcon({
      html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" width="14" height="14"><circle cx="7" cy="7" r="5.5" fill="#15803d" stroke="white" stroke-width="2"/></svg>',
      iconSize: [14, 14], iconAnchor: [7, 7], className: '',
    });

    L.marker([endLat, endLon], { icon: endIcon }).addTo(map);

    if (hasStart) {
      L.marker([startLat, startLon], { icon: startIcon }).addTo(map);
      map.fitBounds([[startLat, startLon], [endLat, endLon]], { padding: [24, 24] });
    } else {
      map.setView([endLat, endLon], 10);
    }
  }
</script>

<style>
  #post-mini-map { overflow: hidden; }
</style>
